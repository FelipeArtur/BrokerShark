# Copie este arquivo para .env e preencha os valores
TELEGRAM_TOKEN=seu_token_aqui
TELEGRAM_CHAT_ID=seu_chat_id_aqui

# Banco de dados
DB_PATH=/home/SEU_USUARIO/brokershark/data/brokershark.db

# Backup local (HDD ou outro diretório externo — obrigatório)
LOCAL_BACKUP_DIR=/mnt/seu-hdd/brokershark/backups

# Backup Google Drive — usa a mesma service account das credenciais
GOOGLE_CREDENTIALS=/home/SEU_USUARIO/brokershark/credentials/service_account.json
DRIVE_BACKUP_FOLDER=BrokerShark Backups

# Dashboard (opcional — padrão: 8080)
DASHBOARD_PORT=8080

# Ollama — IA conversacional (qwen2.5:7b recomendado para RX 6600M)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT=60
